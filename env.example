# ============ APPLICATION SETTINGS ============
APP_NAME=LearnMate - Secure Auth System
APP_VERSION=1.0.0
DEBUG=False

# ============ DATABASE SETTINGS ============
# Use 'sqlite' for development or 'postgresql' for production
DB_TYPE=sqlite
DB_PATH=chatbot_auth.db

# PostgreSQL Configuration (if using PostgreSQL)
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_auth

# ============ JWT & SECURITY SETTINGS ============
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256

# ============ PASSWORD SETTINGS ============
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=True
REQUIRE_LOWERCASE=True
REQUIRE_DIGITS=True
REQUIRE_SPECIAL_CHARS=True
BCRYPT_LOG_ROUNDS=12

# ============ RATE LIMITING ============
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_ENABLED=True

# ============ EMAIL SETTINGS ============
# Email provider: 'smtp', 'sendgrid', or 'gmail'
EMAIL_PROVIDER=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@skillzlearn.com
FROM_NAME=SkillzLearn Support

# ============ SESSION SETTINGS ============
SESSION_TIMEOUT_MINUTES=60
REMEMBER_ME_DAYS=30
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ CHATBOT SETTINGS ============
CHATBOT_API_URL=https://kinvcreation4655.streamlit.app
CHATBOT_REQUIRE_AUTH=True

# ============ ADMIN SETTINGS ============
DEFAULT_ADMIN_EMAIL=admin@skillzlearn.com
DEFAULT_ADMIN_PASSWORD=AdminPassword123!

# ============ FEATURE FLAGS ============
ENABLE_SOCIAL_LOGIN=False
ENABLE_2FA=False
ENABLE_EMAIL_VERIFICATION=True
ENABLE_PASSWORD_RESET=True

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=app.log
